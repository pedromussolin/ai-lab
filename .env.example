# ============================================================
# AI LAB - Environment Configuration
# Copy this file to .env and fill in your values
# ============================================================

# Application
APP_NAME="AI Lab"
APP_ENV=development
DEBUG=true
SECRET_KEY=change-me-to-a-long-random-secret-key-in-production
API_KEY=your-api-key-here

# Database
DATABASE_URL=postgresql+asyncpg://ailab:ailab@localhost:5432/ailab
DATABASE_URL_SYNC=postgresql+psycopg2://ailab:ailab@localhost:5432/ailab
DB_POOL_SIZE=10
DB_MAX_OVERFLOW=20

# Redis
REDIS_URL=redis://localhost:6379/0

# OpenAI
OPENAI_API_KEY=sk-...
OPENAI_DEFAULT_MODEL=gpt-4o
OPENAI_EMBEDDING_MODEL=text-embedding-3-large

# Anthropic
ANTHROPIC_API_KEY=sk-ant-...
ANTHROPIC_DEFAULT_MODEL=claude-sonnet-4-5

# Azure OpenAI / AI Foundry
AZURE_OPENAI_API_KEY=
AZURE_OPENAI_ENDPOINT=https://your-resource.openai.azure.com/
AZURE_OPENAI_API_VERSION=2024-08-01-preview
AZURE_OPENAI_DEPLOYMENT=gpt-4o
AZURE_OPENAI_EMBEDDING_DEPLOYMENT=text-embedding-3-large

# Azure AI Search
AZURE_SEARCH_ENDPOINT=https://your-search.search.windows.net
AZURE_SEARCH_API_KEY=
AZURE_SEARCH_INDEX=ai-lab-docs

# Default LLM Provider (openai | anthropic | azure)
DEFAULT_LLM_PROVIDER=openai
DEFAULT_EMBEDDING_PROVIDER=openai

# LangSmith
LANGCHAIN_TRACING_V2=true
LANGCHAIN_API_KEY=
LANGCHAIN_PROJECT=ai-lab
LANGCHAIN_ENDPOINT=https://api.smith.langchain.com

# OpenTelemetry
OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4317
OTEL_SERVICE_NAME=ai-lab-api
OTEL_TRACES_EXPORTER=otlp

# Rate limiting
RATE_LIMIT_PER_MINUTE=60

# Uploads
UPLOAD_DIR=./uploads
MAX_UPLOAD_SIZE_MB=50

# Log level
LOG_LEVEL=INFO
